# Copy to .fkst/env and edit. scripts/run.sh sources this file when present.

# Path to a built fkst-framework binary (usually a sibling fkst-substrate checkout).
BIN=/Users/eanzhao/Code/fkst-substrate/target/debug/fkst-framework

# --- Alerting posture -------------------------------------------------------
# The single real-write switch. Unset or != 1 means every alert is a dry-run
# log line ("OUTBOUND mode=dry-run"). Flip to 1 only after a burn-in period.
#FKST_ALERT_WRITE=0

# Default delivery uses a NyxID-managed Lark bot. No raw Lark secret is stored
# here; nyxid proxy request resolves the bot credential for this service slug.
#ALERT_DELIVERY_MODE=lark
#NYXID_URL=https://nyx.chrono-ai.fun
#ALERT_LARK_NYXID_SERVICE=api-lark-bot-7
#ALERT_LARK_CHAT_ID=oc_f10274a38c354472507026f0695fb840

# Legacy webhook mode receiving {"text": "..."} JSON posts (Slack-compatible).
# Set ALERT_DELIVERY_MODE=webhook to use this path.
#ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
# Optional separate channel for severity=critical alerts.
#ALERT_WEBHOOK_URL_CRITICAL=
# Optional separate channel used only by the alert-proxy dead_letter meta-alert.
#ALERT_FALLBACK_WEBHOOK_URL=

# --- Analysis tuning --------------------------------------------------------
# Minimum severity that becomes an alert: critical | high | medium | low.
#AUDIT_ALERT_MIN_SEVERITY=high

# --- Aevatar audit trail polling through NyxID ------------------------------
# Set to 1 to poll GET /api/audit/trail every minute via:
# nyxid proxy request "$AEVATAR_AUDIT_NYXID_SERVICE" "$AEVATAR_AUDIT_PATH..."
# NyxID supplies the stored Aevatar credential/identity; do not paste raw tokens.
#AEVATAR_AUDIT_ENABLED=1
#AEVATAR_AUDIT_NYXID_SERVICE=aevatar
#AEVATAR_AUDIT_PATH=/api/audit/trail
# Default scan covers the last 24h and processes up to 1000 records per tick.
# Aevatar clamps page size to 500 max, so 1000 records is normally 2 pages.
# Expanded state-change audit coverage may need a larger budget on busy hosts;
# raise both limits together only after checking API/NyxID capacity.
#AEVATAR_AUDIT_TAKE=500
#AEVATAR_AUDIT_MAX_RECORDS=1000
#AEVATAR_AUDIT_MAX_PAGES_PER_TICK=2
#AEVATAR_AUDIT_LOOKBACK_HOURS=24
# Optional filters accepted by Aevatar. Use __all__ only if your NyxID identity
# has Aevatar admin access for cross-scope reads.
#AEVATAR_AUDIT_SCOPE=
#AEVATAR_AUDIT_ACTOR_ID=
#AEVATAR_AUDIT_IDENTITY_KEY_ID=
# Optional RFC3339 lower/upper bounds. If AEVATAR_AUDIT_FROM is unset, the
# watcher uses the rolling lookback window above so startup always has data.
#AEVATAR_AUDIT_FROM=
#AEVATAR_AUDIT_TO=

# --- Instability detection (stability-sentinel) -----------------------------
# Evaluate instability signals from aevatar-events.jsonl + engine dead-letter
# logs every 5 minutes (the cron always ticks; the department is a no-op unless
# enabled). Detection is rule-based — no LLM in the decision path.
#STABILITY_DETECT_ENABLED=1
# 30-minute buckets; a signal must survive across windows to escalate.
#STABILITY_BUCKET_MINUTES=30
#STABILITY_LOOKBACK_BUCKETS=8
# recurring-failure: fails in >=N of the lookback buckets AND >=M total fails.
#STABILITY_RECUR_BUCKETS=3
#STABILITY_MIN_FAILURES=5
# error-spike: absolute floors + multiple-of-baseline delta.
#STABILITY_SPIKE_MIN_TOTAL=10
#STABILITY_SPIKE_MIN_FAILS=5
#STABILITY_SPIKE_FACTOR=3
#STABILITY_SPIKE_DELTA=0.25
# flapping: fail<->success transitions within the last 4 buckets.
#STABILITY_FLAP_TRANSITIONS=6
#STABILITY_FLAP_MIN_EACH=3
# pipeline-dead-letter: DEAD_LETTER lines sharing (QUEUE, ERROR_CLASS).
#STABILITY_DLQ_THRESHOLD=3
#STABILITY_DLQ_WINDOW_MINUTES=60
# Consecutive quiet covered buckets before an incident auto-closes its issue.
# Buckets with no data are "insufficient data", never quiet.
#STABILITY_QUIET_WINDOWS=6
# Minimum hours between recurrence comments on one incident's issue.
#STABILITY_COMMENT_COOLDOWN_HOURS=6
# Optional codex-written 分析 paragraph in issue bodies; fail-open, filing
# never depends on it.
#STABILITY_LLM_SUMMARY=0

# --- GitHub issue filing (issue-proxy) ---------------------------------------
# The single real-write switch for GitHub. Unset or != 1 means every issue
# action is a dry-run log line ("ISSUE_OUTBOUND mode=dry-run") and no dedup
# marker is written, so flipping to 1 later back-fills. Dry-run still runs a
# daily read-only gh auth probe so burn-in proves writability.
#FKST_ISSUE_WRITE=0
#FKST_ISSUE_REPO=eanz17/fkst-audit-log
# gh uses the locally-authed CLI via exec_argv; nyxid routes through the broker
# (set ISSUE_GITHUB_NYXID_SERVICE for headless hosts).
#FKST_ISSUE_TRANSPORT=gh
#ISSUE_GITHUB_NYXID_SERVICE=api-github
# Close the GitHub issue automatically after the quiet-window recovery. A human
# closing an issue with a mute label (below) always wins over re-filing.
#FKST_ISSUE_AUTOCLOSE=1
# Hard anti-spam budgets: max created issues per day / max concurrent open.
# Exceeding a budget is acked and raises an issue-budget-exhausted alert.
#FKST_ISSUE_MAX_PER_DAY=5
#FKST_ISSUE_MAX_OPEN=10
# A CLOSED issue whose title carries the fingerprint and any of these labels
# permanently suppresses re-filing that fingerprint.
#FKST_ISSUE_MUTE_LABELS=fkst-mute,wontfix

# --- Auto issue solving (issue-watcher -> issue-solver -> issue-proxy.deliver) -
# Discover the current gh account's open, label-gated issues and solve them with
# a consensus loop (claude supervises, codex does the coding), then deliver a
# DRAFT PR + issue comment. Two independent switches:
#   ISSUE_SOLVE_ENABLED=1  turns on discovery + solving (the heavy part: it runs
#                          claude/codex against a scratch clone). No tasks are
#                          dispatched and nothing is solved while unset.
#   FKST_ISSUE_WRITE=1     (shared with issue filing above) is the ONLY switch
#                          that lets the draft PR / comment actually post. Unset
#                          => deliver logs "OUTBOUND mode=dry-run" and posts
#                          nothing, so you can watch what WOULD ship first.
#ISSUE_SOLVE_ENABLED=1
# Where to look and who to look for. @me tracks the locally-authed gh account.
#ISSUE_SOLVE_REPO=aevatarAI/aevatar
#ISSUE_SOLVE_AUTHOR=@me
# Only issues carrying this label are candidates (opt-in, avoids swarming).
#ISSUE_SOLVE_LABEL=fkst-solve
# Issues carrying any of these are NOT fresh candidates (in-flight/done/muted).
#ISSUE_SOLVE_SKIP_LABELS=fkst-solving,fkst-solved,fkst-mute,wontfix
# Max issues pulled per 10-minute discovery tick.
#ISSUE_SOLVE_MAX=5
# Consensus loop shape (per issue).
#ISSUE_SOLVE_CANDIDATES=3
#ISSUE_SOLVE_JUDGES=3
#ISSUE_SOLVE_ROUNDS=2
# Set 0 if the host has no dotnet SDK; judges then skip the build gate.
#ISSUE_SOLVE_DOTNET=1
# Branch the draft PR forks from (aevatar repos default to dev).
#ISSUE_SOLVE_BASE_BRANCH=dev
# Scratch parent for per-issue clones. Unset => a fresh mktemp dir under TMPDIR
# (OUTSIDE this repo), auto-removed after each solve. Set to an absolute dir to
# relocate. The overall per-issue solve timeout (seconds) is separate.
#ISSUE_SOLVE_WORKROOT=
#ISSUE_SOLVE_TIMEOUT=2400
# Hard daily cap on real solution deliveries per repo (draft PRs + comments),
# a backstop against any dedup surprise bursting PRs onto a public repo.
#FKST_SOLUTION_MAX_PER_DAY=5
# Overrides for the black-box solver / PR-opener commands (defaults shown).
#ISSUE_SOLVE_CMD=scripts/consensus-solve.sh
#ISSUE_SOLUTION_PR_CMD=scripts/open-solution-pr.sh
# SECURITY: consensus-solve.sh runs claude (bypassPermissions) + codex
# (bypass-sandbox) — i.e. agent-authored code with this host's privileges —
# against an UNTRUSTED issue body. The scratch clone is kept outside your repo,
# but that is not an OS jail. For issues you do not fully trust, run the engine
# inside a container/VM scoped to only the credentials it needs.

# --- Evidence redaction before anything reaches GitHub ----------------------
# Generic rules (sensitive key=value masking, bearer tokens, URL userinfo,
# long hex, JWTs) are built in. Deployment-specific additions belong in the
# UNCOMMITTED .fkst/env, not in this example:
#   FKST_REDACT_EXTRA_KEYS      extra key names to mask (comma-separated)
#   FKST_REDACT_EXTRA_PATTERNS  safe Lua-pattern subset, semicolon-separated,
#                               with a literal prefix and at most one `+`
#   FKST_REDACT_TRUNC_KEYS      keys whose values keep only the first 8 chars
#                               (default: actor,identityKey,correlation,scope)
#FKST_REDACT_EXTRA_KEYS=
#FKST_REDACT_EXTRA_PATTERNS=
#FKST_REDACT_TRUNC_KEYS=actor,identityKey,correlation,scope

# --- Engine rate limiting (optional) ---------------------------------------
# Host-level token bucket for curl calls: <burst>,<refill per minute>.
#FKST_RATE_POOL_ROOT=~/.fkst/rate-pools
#FKST_RATE_POOL_CURL=30,30
