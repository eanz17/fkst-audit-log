# Copy to .fkst/aevatar-devloop.env and chmod 600 before running the launcher.
# This profile belongs to the independent official Aevatar github-devloop host.

BIN=/Users/you/Code/fkst-substrate/target/debug/fkst-framework
FKST_PLATFORM_ROOT=/Users/you/Code/fkst-packages
# Python >=3.10 is required. Python 3.11+ includes tomllib.
FKST_PYTHON=/path/to/python3.11

FKST_AEVATAR_DEVLOOP_STATE_ROOT=/Users/you/.local/state/fkst-audit-log/aevatar-devloop
FKST_HOST_ROOT=/Users/you/.local/state/fkst-audit-log/aevatar-devloop/host
FKST_DURABLE_ROOT=/Users/you/.local/state/fkst-audit-log/aevatar-devloop/durable
FKST_RATE_POOL_ROOT=/Users/you/.local/state/fkst-audit-log/aevatar-devloop/rate-pools

# Use an SSH remote when direct HTTPS access to github.com is unavailable.
FKST_AEVATAR_REMOTE=git@github.com:aevatarAI/aevatar.git
FKST_AEVATAR_BRANCH=dev
FKST_AEVATAR_HOST_BRANCH=fkst-local/audit-devloop-host

FKST_GITHUB_REPO=aevatarAI/aevatar
# Must equal the audit supervisor's FKST_ISSUE_BOT_LOGIN and the login returned
# by `gh api user`; author-policy mismatch fails closed before claim/consensus.
FKST_GITHUB_BOT_LOGIN=eanz17
FKST_GITHUB_CLAIM_MODE=assignee
FKST_GITHUB_PROXY_POLL_LABEL_PREFIX=fkst-dev:
# Cover the current Aevatar backlog promptly after a cold start (official max).
FKST_GITHUB_PROXY_REPLAY_BUDGET=100
# Real writes require BOTH this value and `start --write`.
FKST_GITHUB_WRITE=0

# Aevatar does not compose github-devloop-integration, so PRs target dev.
FKST_DEVLOOP_UPSTREAM_BRANCH=dev
FKST_DEVLOOP_INTEGRATION_BRANCH=dev
FKST_DEVLOOP_MAX_INFLIGHT=1
FKST_DEVLOOP_TEST_COMMAND='dotnet test aevatar.slnx --nologo && bash tools/ci/architecture_guards.sh'
FKST_OUTPUT_LANG=zh

FKST_RATE_POOL_GH=50,50
FKST_NO_AUTOBUILD=1
